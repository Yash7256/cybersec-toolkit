REDIS_PASSWORD=changeme-generate-a-strong-password
WORKERS=1

# -----------------------------------------------------------------------
# Clerk Authentication — required for authenticated API requests
# Get these values from https://dashboard.clerk.com → Your App → API Keys
# -----------------------------------------------------------------------

# Clerk publishable key (safe to expose in frontend bundles)
CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_publishable_key

# Clerk secret key — keep this server-side ONLY, never commit or expose in bundles
CLERK_SECRET_KEY=sk_test_replace_with_your_secret_key

# JWKS endpoint for your Clerk instance, e.g.:
# https://<your-clerk-subdomain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-clerk-subdomain.clerk.accounts.dev/.well-known/jwks.json

# Issuer URL for your Clerk instance, e.g.:
# https://<your-clerk-subdomain>.clerk.accounts.dev
CLERK_ISSUER=https://your-clerk-subdomain.clerk.accounts.dev

# Vite environment variable for the React frontend (same value as CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_publishable_key
